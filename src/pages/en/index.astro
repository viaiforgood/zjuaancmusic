---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout lang="en" title="The 1st North American Chinese AI Music Creation & Creativity Contest 2026–2027" description="Co-hosted by ZJUAA NC and NACUAANC. Write the stories of the Chinese Diaspora with AI." path="/">
  <div class="max-w-4xl mx-auto px-6 space-y-12">
    <!-- Hero -->
    <header class="text-center py-10 space-y-4">
      <div class="inline-flex items-center gap-x-2 bg-blue-950/40 text-blue-400 px-4 py-1.5 rounded-full text-xs font-semibold border border-blue-900/30">
        <span class="w-1.5 h-1.5 bg-blue-400 rounded-full animate-ping"></span>
        <span>Write the Stories of the Chinese Diaspora with AI · Special Tribute to ZJU's 130th Anniversary</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-slate-200 leading-tight mt-2">
        The 1st North American Chinese AI Music<br><span class="ai-gradient">Creation & Creativity Contest 2026–2027</span>
      </h1>
      <p class="max-w-2xl mx-auto text-slate-400 text-base md:text-lg leading-relaxed">
        Open to all Chinese living in North America with no university affiliation required. Create your musical stories with AI!
      </p>
      <div class="pt-4 flex justify-center gap-4">
        <a href="#register" class="px-6 py-3 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold transition-all shadow-lg hover:scale-105">
          Register Now
        </a>
        <a href="#details" class="px-6 py-3 rounded-xl bg-slate-900 hover:bg-slate-800 text-slate-200 border border-slate-800 font-bold transition-all hover:scale-105">
          Details
        </a>
      </div>
    </header>

    <!-- Hero Image Banner -->
    <div class="relative w-full h-56 md:h-80 rounded-3xl overflow-hidden border border-slate-900 shadow-2xl bg-slate-900 flex items-center justify-center group">
      <img src="/images/hero.jpg" alt="AI Music Banner" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.01]" />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950/50 to-transparent"></div>
    </div>

    <!-- Main Content Section -->
    <div id="details" class="grid md:grid-cols-3 gap-8 pt-6">
      
      <!-- Left Column: Details -->
      <div class="md:col-span-2 space-y-10">
        
        <!-- About the Contest -->
        <section class="bg-slate-900/20 border border-slate-900 rounded-3xl p-6 md:p-8 space-y-4 shadow-xl">
          <h2 class="text-2xl font-bold text-slate-200 flex items-center gap-x-3">
            <i class="fa-solid fa-bullseye text-blue-400"></i>
            <span>About the Contest / 大赛宗旨</span>
          </h2>
          <p class="text-slate-300 text-sm leading-relaxed">
            This competition is co-hosted by the <strong>Zhejiang University Alumni Association of North Carolina (ZJUAA NC)</strong> and <strong>NACUAANC</strong>, supported by multiple US East ZJU alumni associations, as well as NACUAA chapters in Northern California, Silicon Valley, Southern California, and other organizations.
          </p>
          <p class="text-slate-300 text-sm leading-relaxed">
            This is the <strong>1st AI Music Creation & Creativity Contest built specifically for the Chinese diaspora in North America</strong>. We welcome all Chinese residents, immigrants, international students, and friends in North America to participate, with no university affiliation required.
          </p>
          <p class="text-slate-300 text-sm leading-relaxed">
            Creators are encouraged to partner with AI to express Chinese stories, emotions, cultural fusion, and innovation in North America. A "Special Alma Mater Award" is also established to honor Zhejiang University's 130th Anniversary.
          </p>
        </section>

        <!-- Eligibility -->
        <section class="bg-slate-900/20 border border-slate-900 rounded-3xl p-6 md:p-8 space-y-4 shadow-xl">
          <h2 class="text-2xl font-bold text-slate-200 flex items-center gap-x-3">
            <i class="fa-solid fa-id-card text-blue-400"></i>
            <span>Eligibility / 参赛资格</span>
          </h2>
          <ul class="list-disc pl-5 text-sm text-slate-300 space-y-2">
            <li>Chinese residents, immigrants, students, and friends living in North America</li>
            <li>No age limit, no university affiliation required</li>
            <li>Individual or team submissions welcome</li>
          </ul>
        </section>

        <!-- Structure -->
        <section class="bg-slate-900/20 border border-slate-900 rounded-3xl p-6 md:p-8 space-y-4 shadow-xl">
          <h2 class="text-2xl font-bold text-slate-200 flex items-center gap-x-3">
            <i class="fa-solid fa-sitemap text-blue-400"></i>
            <span>Contest Structure (3 Stages · 8 Hubs)</span>
          </h2>
          <div class="grid sm:grid-cols-3 gap-4">
            <div class="bg-blue-950/20 border border-blue-900/20 p-4 rounded-2xl text-center">
              <div class="text-blue-400 font-extrabold text-lg">Preliminaries</div>
              <div class="text-xs text-slate-400 mt-2">Auditions across 8 hubs (<a href="https://nc.zjuaanc.org" target="_blank" class="text-blue-400 hover:underline">NC</a>, <a href="https://dc.zjuaanc.org" target="_blank" class="text-blue-400 hover:underline">DC</a>, <a href="https://tn.zjuaanc.org" target="_blank" class="text-blue-400 hover:underline">TN</a>, <a href="https://fl.zjuaanc.org" target="_blank" class="text-blue-400 hover:underline">FL</a>, <a href="https://pa.zjuaanc.org" target="_blank" class="text-blue-400 hover:underline">PA</a>, <a href="https://tx.zjuaanc.org" target="_blank" class="text-blue-400 hover:underline">TX</a>, <a href="https://ca.zjuaanc.org" target="_blank" class="text-blue-400 hover:underline">CA</a>, <a href="https://wa.zjuaanc.org" target="_blank" class="text-blue-400 hover:underline">WA</a>)</div>
            </div>
            <div class="bg-blue-950/20 border border-blue-900/20 p-4 rounded-2xl text-center">
              <div class="text-blue-400 font-extrabold text-lg">Semifinals</div>
              <div class="text-xs text-slate-400 mt-2">East Alliance vs West Alliance in a major digital showdown.</div>
            </div>
            <div class="bg-blue-950/20 border border-blue-900/20 p-4 rounded-2xl text-center">
              <div class="text-blue-400 font-extrabold text-lg">Grand Finals</div>
              <div class="text-xs text-slate-400 mt-2">Finalists from both alliances compete for top awards.</div>
            </div>
          </div>
        </section>

        <!-- Categories -->
        <section class="bg-slate-900/20 border border-slate-900 rounded-3xl p-6 md:p-8 space-y-4 shadow-xl">
          <h2 class="text-2xl font-bold text-slate-200 flex items-center gap-x-3">
            <i class="fa-solid fa-music text-blue-400"></i>
            <span>Categories (8 Creative Directions)</span>
          </h2>
          <p class="text-xs text-slate-400">Creators are encouraged to blend AI music-making tools (e.g. Suno, Udio, ChatGPT) across categories:</p>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-center">
            <div class="bg-slate-900/40 p-3 rounded-xl border border-slate-800 text-sm font-semibold text-slate-200">Poetry Writing</div>
            <div class="bg-slate-900/40 p-3 rounded-xl border border-slate-800 text-sm font-semibold text-slate-200">Lyrics Writing</div>
            <div class="bg-slate-900/40 p-3 rounded-xl border border-slate-800 text-sm font-semibold text-slate-200">Composition</div>
            <div class="bg-slate-900/40 p-3 rounded-xl border border-slate-800 text-sm font-semibold text-slate-200">Arranging</div>
            <div class="bg-slate-900/40 p-3 rounded-xl border border-slate-800 text-sm font-semibold text-slate-200">Vocals</div>
            <div class="bg-slate-900/40 p-3 rounded-xl border border-slate-800 text-sm font-semibold text-slate-200">A Cappella</div>
            <div class="bg-slate-900/40 p-3 rounded-xl border border-slate-800 text-sm font-semibold text-slate-200">Instrumental</div>
            <div class="bg-slate-900/40 p-3 rounded-xl border border-slate-800 text-sm font-semibold text-slate-200">Music Video / MV</div>
          </div>
        </section>

        <!-- Special Awards -->
        <section class="bg-slate-900/20 border border-slate-900 rounded-3xl p-6 md:p-8 space-y-4 shadow-xl">
          <h2 class="text-2xl font-bold text-slate-200 flex items-center gap-x-3">
            <i class="fa-solid fa-trophy text-blue-400"></i>
            <span>Special Awards</span>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-slate-900/40 p-4 rounded-2xl border border-slate-800 space-y-1">
              <div class="text-sm font-bold text-yellow-400">🎓 Special Alma Mater Award</div>
              <p class="text-xs text-slate-400">Dedicated tribute to Zhejiang University's 130th Anniversary.</p>
            </div>
            <div class="bg-slate-900/40 p-4 rounded-2xl border border-slate-800 space-y-1">
              <div class="text-sm font-bold text-blue-400">📖 Best Chinese Story Award</div>
              <p class="text-xs text-slate-400">Profound expression of Chinese stories and emotions in North America.</p>
            </div>
            <div class="bg-slate-900/40 p-4 rounded-2xl border border-slate-800 space-y-1">
              <div class="text-sm font-bold text-purple-400">🌐 Best East-West Fusion Award</div>
              <p class="text-xs text-slate-400">Innovative blending of Eastern and Western musical traditions.</p>
            </div>
            <div class="bg-slate-900/40 p-4 rounded-2xl border border-slate-800 space-y-1">
              <div class="text-sm font-bold text-emerald-400">⚡ Best AI Creative Application Award</div>
              <p class="text-xs text-slate-400">Outstanding integration of cutting-edge AI technologies in art.</p>
            </div>
          </div>
        </section>

        <!-- Call for Sponsors & Partners -->
        <section class="bg-slate-900/20 border border-slate-900 rounded-3xl p-6 md:p-8 space-y-6 shadow-xl">
          <h2 class="text-2xl font-bold text-slate-200 flex items-center gap-x-3">
            <i class="fa-solid fa-handshake-angle text-blue-400"></i>
            <span>Call for Sponsors & Partners</span>
          </h2>
          <p class="text-slate-300 text-sm leading-relaxed">
            We welcome corporate sponsors, community organizations, and individual donors to join us! <strong>All sponsorships are eligible for US 501(c)(3) tax-deductible receipts issued by VI AI Foundation / VI AI for Good Foundation.</strong>
          </p>
          <div class="space-y-4">
            <div class="border-l-4 border-yellow-500 pl-4 space-y-1">
              <div class="text-sm font-bold text-yellow-500">💎 Diamond Sponsor ($5,000+)</div>
              <p class="text-xs text-slate-400">Top-tier exposure, Grand Finals naming rights, main visual logo, thank-you video, headline homepage feature.</p>
            </div>
            <div class="border-l-4 border-slate-300 pl-4 space-y-1">
              <div class="text-sm font-bold text-slate-300">⚪ Platinum Sponsor ($3,000 – $4,999)</div>
              <p class="text-xs text-slate-400">Semifinals or Finals stage naming, prominent website logo, media feature, workshop naming rights.</p>
            </div>
            <div class="border-l-4 border-yellow-600 pl-4 space-y-1">
              <div class="text-sm font-bold text-yellow-600">🟡 Gold Sponsor ($1,500 – $2,999)</div>
              <p class="text-xs text-slate-400">Hub stage naming rights, logo on posters, certificate appreciation, social media campaigns.</p>
            </div>
            <div class="border-l-4 border-blue-400 pl-4 space-y-1">
              <div class="text-sm font-bold text-blue-400">⚪ Silver Sponsor ($800 – $1,499)</div>
              <p class="text-xs text-slate-400">Website logo feature, promotional material mention, winner list acknowledgment.</p>
            </div>
            <div class="border-l-4 border-amber-700 pl-4 space-y-1">
              <div class="text-sm font-bold text-amber-700">🟤 Bronze Sponsor ($300 – $799)</div>
              <p class="text-xs text-slate-400">Website and donor list feature, social media shout-outs.</p>
            </div>
          </div>
          <p class="text-xs text-slate-400 border-t border-slate-900 pt-4 leading-relaxed">
            🤝 <strong>Special Contribution Partners</strong>: In-kind or service sponsorships (prizes, venue, tech support, etc.).<br>
            🤝 <strong>Co-Hosts / Co-Organizers</strong>: Alumni groups and organizations are welcome to co-host with custom benefits.
          </p>
        </section>

        <!-- Footer / Organization -->
        <section class="bg-slate-900/20 border border-slate-900 rounded-3xl p-6 md:p-8 space-y-4 shadow-xl">
          <h2 class="text-2xl font-bold text-slate-200 flex items-center gap-x-3">
            <i class="fa-solid fa-users text-blue-400"></i>
            <span>Organization / Footer</span>
          </h2>
          <div class="grid sm:grid-cols-2 gap-6 text-sm">
            <div>
              <div class="font-bold text-slate-300">Co-Hosts</div>
              <div class="text-xs text-slate-400 mt-1.5 leading-relaxed">
                ZJUAA NC (北卡浙大校友会)<br>
                NACUAANC (北加高校联盟)
              </div>
            </div>
            <div>
              <div class="font-bold text-slate-300">Partner Organizations</div>
              <div class="text-xs text-slate-400 mt-1.5 leading-relaxed">
                US East ZJU Alumni Associations<br>
                NACUAA Northern CA, Silicon Valley, and Southern CA Chapters
              </div>
            </div>
            <div>
              <div class="font-bold text-slate-300">Technical Support</div>
              <div class="text-xs text-slate-400 mt-1.5 leading-relaxed">
                VI AI Foundation<br>
                VI AI for Good Foundation
              </div>
            </div>
            <div>
              <div class="font-bold text-slate-300">Contact & Website</div>
              <div class="text-xs text-slate-400 mt-1.5 leading-relaxed">
                Email: <a href="mailto:music@zjuaanc.org" class="text-blue-400 hover:underline">music@zjuaanc.org</a><br>
                WeChat: michaelhuo<br>
                Website: music.zjuaanc.org
              </div>
            </div>
          </div>
        </section>

      </div>

      <!-- Right Column: Timeline & Contact -->
      <div class="space-y-6">

        <!-- Register -->
        <div id="register" class="bg-blue-950/20 border border-blue-900/30 rounded-3xl p-6 space-y-4 shadow-xl text-center">
          <h3 class="text-base font-bold text-slate-200 flex items-center justify-center gap-x-2">
            <i class="fa-solid fa-qrcode text-blue-500"></i>
            <span>Scan to Register</span>
          </h3>
          <div class="flex flex-col items-center gap-2">
            <img src="/images/wechat_match_registration_qr.jpg" alt="Contest Registration WeChat Group" class="w-36 h-36 rounded-2xl border border-slate-800 shadow-lg object-cover mx-auto" />
            <span class="text-xs text-slate-400 mt-1">Scan QR code to join official registration group</span>
          </div>
        </div>
        
        <!-- Key Dates -->
        <div class="bg-slate-900/30 border border-slate-900 rounded-3xl p-6 space-y-6 shadow-xl">
          <h3 class="text-lg font-bold text-slate-200 flex items-center gap-x-2">
            <i class="fa-solid fa-calendar-days text-blue-500"></i>
            <span>Key Dates / 重要时间</span>
          </h3>
          <div class="space-y-4 text-xs">
            <div class="relative pl-6 border-l border-slate-800 pb-2">
              <span class="absolute left-[-4.5px] top-[4px] w-2 h-2 rounded-full bg-blue-500"></span>
              <div class="font-bold text-slate-200">August 28, 2026 (Friday)</div>
              <div class="text-slate-400 mt-0.5">Registration & Submission Deadline (Midnight EDT)</div>
            </div>
            <div class="relative pl-6 border-l border-slate-800 pb-2">
              <span class="absolute left-[-4.5px] top-[4px] w-2 h-2 rounded-full bg-blue-500"></span>
              <div class="font-bold text-slate-200">September 26–28, 2026</div>
              <div class="text-slate-400 mt-0.5">Preliminaries: Results across 8 hubs announced</div>
            </div>
            <div class="relative pl-6 border-l border-slate-800 pb-2">
              <span class="absolute left-[-4.5px] top-[4px] w-2 h-2 rounded-full bg-blue-500"></span>
              <div class="font-bold text-slate-200">September 30, 2026</div>
              <div class="text-slate-400 mt-0.5">Recommend Outstanding Submissions to ZJU Alma Mater</div>
            </div>
            <div class="relative pl-6 border-l border-slate-800 pb-2">
              <span class="absolute left-[-4.5px] top-[4px] w-2 h-2 rounded-full bg-blue-500"></span>
              <div class="font-bold text-slate-200">December 12, 2026 (Saturday)</div>
              <div class="text-slate-400 mt-0.5">Semifinals: East Alliance vs West Alliance</div>
            </div>
            <div class="relative pl-6 pb-1">
              <span class="absolute left-[-4px] top-[4px] w-2 h-2 rounded-full bg-yellow-500"></span>
              <div class="font-bold text-slate-200">February 27, 2027 (Saturday)</div>
              <div class="text-slate-400 mt-0.5">Grand Finals: Finalists showdown for top prizes</div>
            </div>
          </div>
        </div>

        <!-- Contact -->
        <div class="bg-slate-900/30 border border-slate-900 rounded-3xl p-6 space-y-4 shadow-xl">
          <h3 class="text-lg font-bold text-slate-200 flex items-center gap-x-2">
            <i class="fa-solid fa-address-card text-blue-500"></i>
            <span>Committee Contact</span>
          </h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            For sponsorship, co-hosting, and competition inquiries:
          </p>
          <div class="space-y-2 text-xs">
            <div class="flex items-center gap-2 text-slate-300">
              <i class="fa-brands fa-weixin text-blue-400 w-4"></i>
              <span>WeChat: michaelhuo</span>
            </div>
            <div class="flex items-center gap-2 text-slate-300">
              <i class="fa-regular fa-envelope text-blue-400 w-4"></i>
              <a href="mailto:music@zjuaanc.org" class="hover:underline">music@zjuaanc.org</a>
            </div>
          </div>
        </div>

        <!-- Appendix -->
        <div class="bg-slate-900/30 border border-slate-900 rounded-3xl p-6 space-y-3 shadow-xl">
          <h3 class="text-sm font-bold text-slate-200">🔗 Appendix</h3>
          <p class="text-[11px] text-slate-500">Alma Mater Notice: "Invite you to write a song for 130-year-old ZJU!"</p>
          <a href="https://m.thepaper.cn/newsDetail_forward_33388625" target="_blank" class="text-xs text-blue-400 hover:underline flex items-center gap-1">
            <span>View Announcement</span>
            <span>→</span>
          </a>
        </div>

      </div>

    </div>

  </div>
</BaseLayout>
